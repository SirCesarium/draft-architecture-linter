{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Extension",
      "type": "shell",
      "command": "bun run build",
      "options": {
        "cwd": "${workspaceFolder}/editors/vscode"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$esbuild-watch"
    }
  ]
}
